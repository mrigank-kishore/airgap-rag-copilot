# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=localdoc_chunks_dev
QDRANT_COLLECTION_CONFIG=infra/qdrant/collection.local.json

# Model endpoints
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=local-instruct-model
TEI_EMBEDDING_URL=http://localhost:8080
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_VECTOR_SIZE=384
TEI_RERANKER_URL=http://localhost:8081

# Production embedding defaults:
# QDRANT_COLLECTION=localdoc_chunks
# QDRANT_COLLECTION_CONFIG=infra/qdrant/collection.prod.json
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_VECTOR_SIZE=1024

# Observability
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Runtime limits
RAG_TOP_K=25
RAG_RERANK_TOP_K=5
AGENT_RECURSION_LIMIT=10
REQUEST_TIMEOUT_SECONDS=120
